# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.coverage
htmlcov/

# Bridge runtime directory. The tracked bridge SOURCE lives in
# apworld/smo_archipelago/client/; `bridge/smo_ap_bridge/` is a local
# runtime tree that ALSO holds the romfs-extracted maps
# (bridge/smo_ap_bridge/data/shine_map.json, capture_map.json, and their
# *_review.json). Those are copyrighted Nintendo content — this dir MUST
# stay ignored so they never reach the public repo (Devon, 2026-06-13).
bridge/
apworld/smo_archipelago/client/logs/
apworld/smo_archipelago/client/*.log

# Switch build (NOT submodule paths — those are tracked via .gitmodules)
switch-mod/build/
switch-mod/sd-overlay/atmosphere/contents/*/exefs/subsdk9
switch-mod/sd-overlay/atmosphere/contents/*/exefs/main.npdm
switch-mod/sd-overlay/atmosphere/contents/*/romfs/ap_config.json
switch-mod/src/ap/capture_table.h
# shine_table.h joins committed locations.json with the gitignored
# shine_map.json (extracted Nintendo IP). Each column is individually
# allowed by CLAUDE.md, but the joined (stage, obj_id) → English-name
# mapping IS the load-bearing content of shine_map.json — keep it out
# of git for the same reason capture_table.h is out.
switch-mod/src/ap/shine_table.h

# Symbol dumps - never commit, contain copyrighted material
docs/main-*.nso
docs/symbols-*.json
docs/ghidra/

# Game data extracted from SMO romfs — copyrighted Nintendo content, must
# regenerate on each user's machine. See docs/extract-moon-data.md.
apworld/smo_archipelago/client/data/shine_map.json
apworld/smo_archipelago/client/data/shine_map_review.json
apworld/smo_archipelago/client/data/capture_map.json
apworld/smo_archipelago/client/data/capture_map_review.json
# world_scenarios.json is functional (kingdom internal names + scenario
# numbers) and could be committed for Rules.py to consume at gen time, but
# it's a generated artifact — keep it ignored until that placement decision
# is made (see docs/scenario-gating-logic-design.md §6).
apworld/smo_archipelago/client/data/world_scenarios.json

# Live-AP loopback test artifacts (generated seeds; regenerated on demand
# by apworld/smo_archipelago/tests/test_ap_loopback.py).
apworld/smo_archipelago/tests/seeds/out/
.romfs-cache/
scripts/.extract-venv/
# Moon-rock audit report: contains romfs-derived strings (IsMoonRock-flagged
# shine names). Regenerate via scripts/audit_moon_rock_locations.py.
scripts/.moon_rock_audit.json

# PopTracker pack build artifacts (generated from apworld data; re-run
# scripts/build_poptracker_pack.py to regenerate).
poptracker/build/

# IDE
.vscode/
.idea/
*.swp
*~

# OS
.DS_Store
Thumbs.db

# Local clones we don't track (submodules go in vendor/ instead)
third_party/

# vendor/ holds submodules — tracked via .gitmodules. Don't ignore the dir.
# Common build artifacts inside Archipelago should still be ignored.
vendor/Archipelago/host.yaml
vendor/Archipelago/Players/
vendor/Archipelago/output/
vendor/*/__pycache__/

.claude/worktrees/